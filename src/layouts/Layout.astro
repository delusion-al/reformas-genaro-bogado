<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: hsl(230, 25%, 7%);
            --accent: hsl(265, 90%, 65%);
            --secondary: hsl(180, 100%, 50%);
            --surface: hsla(230, 25%, 15%, 0.6);
            --text-high: hsl(0, 0%, 98%);
            --text-low: hsla(0, 0%, 98%, 0.6);
            --glass-border: hsla(0, 0%, 100%, 0.1);
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-high);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .glass-effect {
            background: var(--surface);
            backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }

        .kinetic-text {
            transition: font-weight 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .shimmer-text {
            background: linear-gradient(90deg, var(--text-high), var(--accent), var(--secondary), var(--text-high));
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 4s linear infinite;
        }

        @keyframes shimmer {
            to { background-position: 200% center; }
        }
    </style>
</head>
<body>
    <slot />
</body>
</html>