---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Premium Structural Improvements by Genaro Bogado" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #0f172a;
      --secondary: #1e293b;
      --accent: #d4af37;
      --text-high: #f8fafc;
      --text-low: #94a3b8;
      --glass: rgba(255, 255, 255, 0.03);
      --glass-border: rgba(255, 255, 255, 0.1);
    }
    body {
      background-color: var(--primary);
      color: var(--text-high);
      font-family: 'Inter', sans-serif;
      margin: 0;
      overflow-x: hidden;
    }
    h1, h2, h3, .font-serif {
      font-family: 'Playfair Display', serif;
    }
    .glass-effect {
      background: var(--glass);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
    }
    .shimmer-text {
      background: linear-gradient(90deg, #fff, var(--accent), #fff);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmer 3s linear infinite;
    }
    @keyframes shimmer {
      to { background-position: 200% center; }
    }
    .kinetic-text {
      display: inline-block;
      transition: transform 0.3s ease;
    }
    .kinetic-text:hover {
      transform: translateY(-5px) scale(1.02);
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>