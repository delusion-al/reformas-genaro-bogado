---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Reformas Genaro Bogado | Arquitectura y Reformas">
  <!-- Glass Navigation -->
  <nav class="fixed top-0 w-full z-50 px-6 py-4">
    <div class="max-w-7xl mx-auto glass-effect rounded-2xl px-6 py-3 flex justify-between items-center">
      <div class="text-2xl font-extrabold tracking-tighter font-serif">
        GENARO <span style="color: var(--accent)">BOGADO</span>
      </div>
      <div class="hidden md:flex gap-8 text-sm font-medium">
        <a href="#services" class="hover:text-[var(--accent)] transition-colors">Servicios</a>
        <a href="#portfolio" class="hover:text-[var(--accent)] transition-colors">Portafolio</a>
        <a href="#process" class="hover:text-[var(--accent)] transition-colors">Proceso</a>
      </div>
      <a href="#contact" class="glass-effect px-5 py-2 rounded-full text-sm font-semibold hover:bg-white/10 transition-all border-[var(--accent)] text-[var(--accent)]">
        Solicitar Presupuesto
      </a>
    </div>
  </nav>

  <!-- Kinetic Hero Section -->
  <section class="relative pt-48 pb-32 px-6 flex flex-col items-center text-center">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[var(--accent)] opacity-10 blur-[150px] rounded-full -z-10"></div>
    
    <h1 class="text-6xl md:text-8xl font-extrabold tracking-tight mb-6 max-w-5xl leading-tight">
      <span class="shimmer-text">Excelencia Estructural</span>
      <br/>
      <span class="kinetic-text">Diseño de Vanguardia</span>
    </h1>
    
    <p class="text-lg md:text-xl text-[var(--text-low)] max-w-2xl mb-10">
      Especialistas en reformas integrales y mejoras estructurales de alta gama. 
      Convertimos espacios obsoletos en obras maestras de funcionalidad y lujo.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <button class="px-8 py-4 rounded-full font-bold text-black transition-transform hover:scale-105" style="background: var(--accent); box-shadow: 0 0 30px rgba(212, 175, 55, 0.4)">
        Empezar mi Proyecto
      </button>
      <button class="glass-effect px-8 py-4 rounded-full font-bold hover:bg-white/5 transition-all">
        Explorar Portafolio
      </button>
    </div>
  </section>

  <!-- Bento Grid Features -->
  <section id="services" class="px-6 py-20 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[260px]">
      
      <!-- Cell A: Structural Masterclass -->
      <div class="md:col-span-2 md:row-span-2 glass-effect rounded-3xl p-8 flex flex-col justify-end group overflow-hidden relative">
        <div class="absolute top-0 right-0 p-8 opacity-20 group-hover:opacity-100 transition-opacity">
          <div class="w-24 h-24 border-2 border-[var(--accent)] rounded-full animate-pulse"></div>
        </div>
        <h3 class="text-3xl font-bold mb-2 font-serif">Ingeniería Estructural</h3>
        <p class="text-[var(--text-low)]">Refuerzos, redistribución de espacios y consolidación de cimientos con normativa técnica avanzada.</p>
        <div class="mt-6 flex gap-2">
          <span class="text-xs px-3 py-1 rounded-full bg-white/10 border border-white/20">ISO Certified</span>
          <span class="text-xs px-3 py-1 rounded-full bg-white/10 border border-white/20">Premium Materials</span>
        </div>
      </div>

      <!-- Cell B: Interior Design -->
      <div class="md:col-span-2 glass-effect rounded-3xl p-8 flex items-center justify-between group hover:border-[var(--accent)] transition-all">
        <div>
          <h3 class="text-2xl font-bold mb-2 font-serif">Interiorismo de Lujo</h3>
          <p class="text-[var(--text-low)]">Estética minimalista y materiales nobles.</p>
        </div>
        <div class="text-4xl group-hover:rotate-12 transition-transform">🏛️</div>
      </div>

      <!-- Cell C: Turnkey Solutions -->
      <div class="glass-effect rounded-3xl p-8 flex flex-col justify-center group hover:bg-white/5 transition-all">
        <h3 class="text-xl font-bold mb-2 font-serif">Llave en Mano</h3>
        <p class="text-sm text-[var(--text-low)]">Gestión total desde el plano hasta la entrega final.</p>
      </div>

      <!-- Cell D: ROI/Value Increase -->
      <div class="glass-effect rounded-3xl p-8 flex flex-col justify-center group bg-gradient-to-br from-transparent to-[var(--accent)]/10">
        <h3 class="text-xl font-bold mb-2 font-serif">Valorización</h3>
        <p class="text-sm text-[var(--text-low)]">Incrementamos el valor patrimonial de su propiedad.</p>
      </div>

    </div>
  </section>

  <!-- Lead Generation Section -->
  <section id="contact" class="px-6 py-20 max-w-4xl mx-auto text-center">
    <div class="glass-effect p-12 rounded-[3rem] border-t-4 border-t-[var(--accent)]">
      <h2 class="text-4xl font-bold mb-4 font-serif">¿Listo para transformar su espacio?</h2>
      <p class="text-[var(--text-low)] mb-8">Agende una consultoría técnica personalizada con nuestro equipo de arquitectura.</p>
      <form class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
        <input type="text" placeholder="Nombre Completo" class="bg-white/5 border border-white/10 px-6 py-4 rounded-2xl focus:outline-none focus:border-[var(--accent)] transition-all" />
        <input type="email" placeholder="Correo Electrónico" class="bg-white/5 border border-white/10 px-6 py-4 rounded-2xl focus:outline-none focus:border-[var(--accent)] transition-all" />
        <textarea placeholder="Describa su proyecto..." class="md:col-span-2 bg-white/5 border border-white/10 px-6 py-4 rounded-2xl focus:outline-none focus:border-[var(--accent)] transition-all h-32"></textarea>
        <button class="md:col-span-2 py-4 rounded-2xl font-bold text-black transition-all hover:brightness-110" style="background: var(--accent)">
          Enviar Solicitud de Presupuesto
        </button>
      </form>
    </div>
  </section>

  <footer class="py-10 text-center text-sm text-[var(--text-low)]">
    © {new Date().getFullYear()} Reformas Genaro Bogado. Todos los derechos reservados.
  </footer>
</Layout>